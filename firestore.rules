rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isRole(role) {
      // Allow reading the user's own document to check their role.
      // Use get() to safely access fields even if they don't exist.
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return request.auth != null && (
        role == userData.get('role', '') || 
        (userData.get('roles', []) != null && role in userData.get('roles', []))
      );
    }

    // PUBLIC READ, PROTECTED WRITE
    match /{document=**} {
      allow read: if true;
    }

    match /users/{userId} {
      allow create: if true; 
      allow update, delete: if isOwner(userId) || isRole('admin');
    }

    match /tickets/{ticketId} {
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
                    isRole('admin') ||
                    resource.data.driverId == request.auth.uid ||
                    resource.data.ownerId == request.auth.uid
                  );
      allow delete: if request.auth != null && isRole('admin');
    }

    match /customers/{customerId} {
      allow write: if request.auth != null;
    }

    match /settings/{settingId} {
      allow write: if request.auth != null && isRole('admin');
    }

    match /blockedDates/{date} {
      allow write: if request.auth != null && isRole('admin');
    }

    match /projects/{projectId} {
      // Allow creation and reading for any authenticated user
      allow read, create: if request.auth != null;
      // Allow updates for admins, owners, or assigned installers
      allow update: if request.auth != null && (
                    isRole('admin') ||
                    resource.data.ownerId == request.auth.uid ||
                    request.auth.uid in resource.data.installerIds
                  );
      // Only admins can delete
      allow delete: if request.auth != null && isRole('admin');
    }
  }
}

